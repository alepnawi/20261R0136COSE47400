\begin{center}
\begin{tikzpicture}[x=1cm,y=1cm]

% ------------------------------------------------
% Grid constants
% ------------------------------------------------
\def\xLabel{1.40}
\def\xMain{3.60}
\def\xNum{8.55}
\def\xRightA{11.60}
\def\xRightB{12.00}

% ------------------------------------------------
% Global styles
% ------------------------------------------------
\tikzset{
    arrow/.style={->, >=stealth, thick, draw=blue!60!black},
    sidepanel/.style={
        thick, rounded corners=3pt,
        minimum width=5.9cm, minimum height=0.8cm,
        rotate=90, font=\sffamily\bfseries\large
    },
    layerbox/.style={
        draw=blue!60!black, thick, rounded corners=3pt,
        fill=blue!20, align=center,
        minimum width=2.6cm, minimum height=0.72cm,
        font=\sffamily\small
    },
    tokenneutral/.style={
        draw=black!50, thick, rounded corners=3pt,
        fill=white, minimum height=0.7cm,
        font=\sffamily\small
    },
    tokengreen/.style={
        draw=green!60!black, thick, rounded corners=3pt,
        fill=green!20, minimum height=0.7cm,
        font=\sffamily\small
    },
    tokenfinal/.style={
        draw=green!60!black, thick, rounded corners=3pt,
        fill=green!60!black, text=white,
        minimum height=0.7cm,
        font=\sffamily\bfseries\small
    }
}

% ------------------------------------------------
% Background / Main Frame
% ------------------------------------------------
\draw[draw=black!40, thick, rounded corners=5pt, fill=blue!2] (-0.5,0.5) rectangle (19.5,-14.8);

% ------------------------------------------------
% LEFT VERTICAL LABELS
% ------------------------------------------------
\node[sidepanel, draw=orange!80!black, fill=orange!30] at (0.2,-3.25) {Next-token selection};
\node[sidepanel, draw=blue!80!black, fill=blue!30]   at (0.2,-10.8) {Example behavior};

% ------------------------------------------------
% TOP SECTION
% ------------------------------------------------

% LLM Box
\draw[draw=blue!80!black, thick, rounded corners=5pt, fill=blue!5] (1.0,-0.5) rectangle (4.0,-6.0);
\node[font=\sffamily\bfseries\Large, text=blue!80!black] at (2.5,-0.95) {LLM};

\node[layerbox] (l_n)  at (2.5,-1.8) {\textbf{$N$-th layer}\\[-0.2ex]\scriptsize(final layer)};
\node[font=\sffamily]  at (2.5,-2.4) {$\vdots$};
\node[layerbox] (l_24) at (2.5,-3.0) {24th layer};
\node[font=\sffamily]  at (2.5,-3.6) {$\vdots$};
\node[layerbox] (l_16) at (2.5,-4.2) {16th layer};
\node[font=\sffamily]  at (2.5,-4.8) {$\vdots$};
\node[layerbox] (l_8)  at (2.5,-5.4) {8th layer};

% Shallow bucket Box
\draw[draw=blue!80!black, thick, dashed, rounded corners=5pt, fill=white] (4.8,-0.2) rectangle (8.6,-6.3);

\node[
    anchor=north,
    font=\sffamily\bfseries\normalsize
] at (6.7,-0.52) {Shallow bucket};

\node[
    anchor=north,
    font=\sffamily\tiny,
    text width=2.35cm,
    align=center
] at (6.7,-0.82) {Candidate layers: $\{8,16,24,N\}$};

\foreach \y/\label/\hA/\hB/\hC/\hD/\hE in {
    -2.0/N/0.2/0.3/0.6/0.8/0.6,
    -3.2/24/0.2/0.2/0.4/0.7/0.5,
    -4.4/16/0.2/0.2/0.3/0.6/0.2,
    -5.6/8/0.1/0.2/0.4/0.6/0.2
} {
    \node[
        font=\sffamily\tiny,
        anchor=east,
        inner sep=1pt
    ] at (5.22,\y+0.16) {$\label$};

    \draw[thick, blue!60!black] (5.45,\y) -- (8.10,\y);
    \fill[blue!60!black] (5.68,\y) rectangle +(0.25,\hA);
    \fill[blue!60!black] (6.10,\y) rectangle +(0.25,\hB);
    \fill[blue!60!black] (6.52,\y) rectangle +(0.25,\hC);
    \fill[blue!60!black] (6.94,\y) rectangle +(0.25,\hD);
    \fill[blue!60!black] (7.36,\y) rectangle +(0.25,\hE);
}
\node[
    font=\sffamily\footnotesize
] at (6.7,-5.88) {logits / distributions};

% Arrows
\draw[arrow] (l_n.east)  -- (4.8,-1.8);
\draw[arrow] (l_24.east) -- (4.8,-3.0);
\draw[arrow] (l_16.east) -- (4.8,-4.2);
\draw[arrow] (l_8.east)  -- (4.8,-5.4);

% Dynamic layer selection
\draw[draw=purple!80!black, thick, rounded corners=5pt, fill=purple!10] (9.1,-1.5) rectangle (12.0,-6.1);
\node[font=\sffamily\bfseries\normalsize, align=center] at (10.55,-2.05) {Dynamic layer\\selection};
\node[font=\sffamily\normalsize, align=center] at (10.55,-3.25)
{$l_t^* = \arg\max\limits_l$\\[0.35ex]$\mathrm{JSD}(p_{\mathrm{final}}, p_l)$};
\draw[thin, purple!80!black] (9.3,-4.15) -- (11.8,-4.15);
\node[font=\sffamily\tiny, align=center] at (10.55,-5.12) {token-wise\\adaptive\\premature layer};
\draw[arrow] (8.6,-3.2) -- (9.1,-3.2);

% DoLa-FixedAlpha objective
\draw[draw=blue!80!black, thick, rounded corners=5pt, fill=blue!5] (12.5,-1.0) rectangle (16.0,-4.5);
\node[font=\sffamily\bfseries\large] at (14.25,-1.45) {DoLa-FixedAlpha objective:};
\node[align=center, font=\sffamily\normalsize] at (14.25,-2.55)
{$z_t^{\mathrm{DoLa\text{-}FixedAlpha}} =$\\[0.4ex]$z_{\mathrm{final}} - \alpha_{\mathrm{fixed}}\, z_{l_t^*}$};
\draw[thin, blue!80!black] (12.8,-3.42) -- (15.7,-3.42);
\node[font=\sffamily\footnotesize, align=center] at (14.25,-3.82) {fixed-strength\\contrastive decoding};
\draw[arrow] (12.0,-3.2) -- (12.5,-3.2);

% Main refinement
\draw[draw=blue!80!black, thick, dashed, rounded corners=5pt, fill=white] (12.5,-4.9) rectangle (16.0,-6.3);
\node[
    font=\sffamily\bfseries\small
] at (14.25,-5.18) {Main refinement};
\node[
    font=\sffamily\scriptsize,
    align=center
] at (14.25,-5.72) {fixed $\alpha$ \& dynamic layer};
\draw[arrow, dashed] (14.25,-4.9) -- (14.25,-4.5);

% Next token
\draw[draw=green!60!black, thick, dashed, rounded corners=5pt, fill=white] (16.5,-1.0) rectangle (19.1,-5.5);
\node[font=\sffamily\bfseries\normalsize] at (17.8,-1.45) {Next token};
\draw[thick, green!60!black] (16.7,-3.0) -- (18.9,-3.0);
\fill[green!60!black] (16.8,-3.0) rectangle +(0.25,0.3);
\fill[green!60!black] (17.2,-3.0) rectangle +(0.25,0.4);
\fill[green!60!black] (17.6,-3.0) rectangle +(0.25,0.4);
\fill[green!60!black] (18.0,-3.0) rectangle +(0.25,0.5);
\fill[green!60!black] (18.4,-3.0) rectangle +(0.25,0.8);
\node[font=\sffamily\footnotesize] at (16.93,-3.22) {16};
\node[font=\sffamily\footnotesize] at (17.33,-3.22) {24};
\node[font=\sffamily\footnotesize] at (17.73,-3.22) {32};
\node[font=\sffamily\footnotesize] at (18.10,-3.22) {8};
\node[font=\sffamily\footnotesize\bfseries, text=green!60!black] at (18.58,-3.22) {125};
\draw[->, >=stealth, line width=2.2pt, green!60!black] (17.8,-3.6) -- (17.8,-4.1);
\node[
    draw=green!60!black, thick, rounded corners=3pt,
    fill=green!20, font=\sffamily\bfseries\normalsize,
    text=green!60!black,
    minimum width=1.2cm, minimum height=0.6cm
] at (17.8,-4.8) {125};
\draw[arrow] (16.0,-3.0) -- (16.5,-3.0);

% ------------------------------------------------
% PROMPT STRIP
% ------------------------------------------------
\draw[draw=blue!80!black, thick, rounded corners=3pt, fill=gray!10] (1.0,-6.75) rectangle (19.1,-8.05);

\node[
    anchor=west,
    font=\sffamily\bfseries\normalsize
] at (\xLabel,-7.40) {Prompt:};

\node[
    anchor=west,
    align=left,
    text width=15.0cm,
    font=\sffamily\small\itshape
] at (\xMain,-7.40)
{``A merchant wants to choose between jewelry worth \$5{,}000 and electronic gadgets worth \$8{,}000. Jewelry rises by 2.5\% and electronics by 1.2\%. If he maximizes profit, what profit should he expect?''};

% ------------------------------------------------
% GREEDY BOX
% ------------------------------------------------
\draw[draw=red!80!black, thick, rounded corners=3pt, fill=red!5] (1.0,-8.35) rectangle (19.1,-9.45);

\node[anchor=west, font=\sffamily\bfseries\Large] at (\xLabel,-8.90) {Greedy:};

\node[anchor=west, font=\sffamily\normalsize] at (\xMain,-8.90)
{Saved Stage 5 output prediction:};

\node[anchor=west, font=\sffamily\bfseries\normalsize, text=red!80!black] at (\xNum,-8.90)
{155.};

\node[
    anchor=west,
    font=\sffamily\small,
    text=red!80!black,
    text width=5.8cm,
    align=left
] at (\xRightB,-8.90)
{Over-focuses on the higher base price.};

% ------------------------------------------------
% DOLA BOX
% ------------------------------------------------
\draw[draw=orange!80!black, thick, rounded corners=3pt, fill=orange!10] (1.0,-9.75) rectangle (19.1,-10.85);

\node[anchor=west, font=\sffamily\bfseries\Large] at (\xLabel,-10.30) {DoLa:};

\node[anchor=west, font=\sffamily\normalsize] at (\xMain,-10.30)
{Saved Stage 5 output prediction:};

\node[anchor=west, font=\sffamily\bfseries\normalsize, text=orange!80!black] at (\xNum,-10.30)
{132.};

\node[
    anchor=west,
    font=\sffamily\small,
    text=orange!80!black,
    text width=6.5cm,
    align=left
] at (\xRightA,-10.30)
{Static contrast helps, but still misses the correct profit.};

% ------------------------------------------------
% DYNPAC BOX
% ------------------------------------------------
\draw[draw=green!60!black, thick, rounded corners=3pt, fill=green!10] (1.0,-11.15) rectangle (19.1,-14.35);

\node[anchor=west, font=\sffamily\bfseries\Large] at (\xLabel,-11.70) {DoLa-FixedAlpha:};

\node[anchor=west, font=\sffamily\normalsize] at (\xMain,-11.70)
{Saved Stage 5 output prediction:};

\node[anchor=west, font=\sffamily\bfseries\normalsize, text=green!60!black] at (\xNum,-11.70)
{125.};

\node[anchor=west, font=\sffamily\normalsize] at (9.10,-11.70)
{Gold answer:};

\node[anchor=west, font=\sffamily\bfseries\normalsize, text=green!60!black] at (10.95,-11.70)
{125.};

\node[
    anchor=west,
    font=\sffamily\bfseries\normalsize,
    text=green!60!black
] at (\xMain,-12.30)
{Dynamic premature-layer selection produces the correct profit value.};

% Checkmark
\fill[green!60!black] (18.45,-12.00) circle (0.35cm);
\draw[white, line width=2pt] (18.24,-12.01) -- (18.37,-12.17) -- (18.63,-11.77);

% Dashed line
\draw[dashed, green!60!black] (1.3,-12.75) -- (18.8,-12.75);

% Token strip
\node[tokenneutral, minimum width=2.1cm] at (4.6,-13.45) {merchant};
\draw[thick, black!70] (6.15,-13.25) -- (6.15,-13.65);

\node[tokengreen, minimum width=1.9cm] at (7.65,-13.45) {jewelry};
\draw[thick, black!70] (9.0,-13.25) -- (9.0,-13.65);

\node[tokengreen, minimum width=1.4cm] at (10.2,-13.45) {2.5\%};
\draw[thick, black!70] (11.35,-13.25) -- (11.35,-13.65);

\node[tokengreen, minimum width=1.6cm] at (12.65,-13.45) {profit};
\draw[thick, black!70] (13.95,-13.25) -- (13.95,-13.65);

\node[tokenfinal, minimum width=1.5cm] at (15.2,-13.45) {125};

\end{tikzpicture}
\end{center}
